# Required API key for LLM calls
GROQ_API_KEY=your_groq_api_key_here

# Optional override for Groq-compatible endpoint
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# Optional model names
MODEL_SIMPLE=meta-llama/llama-4-scout-17b-16e-instruct
MODEL_COMPLEX=meta-llama/llama-4-scout-17b-16e-instruct
MODEL_CSV=llama-3.3-70b-versatile

# API request timeout (seconds)
API_TIMEOUT=30

# Prompt-based Python execution timeout (seconds)
EXEC_TIMEOUT=35

# Prompt-based max attempts (1 initial + retries)
MAX_ATTEMPTS=3

# CSV-mode Python execution timeout (seconds)
CSV_EXEC_TIMEOUT=35

# CSV-mode max attempts
CSV_MAX_ATTEMPTS=3
